            </section>
            
            <!--========== ABOUT ==========-->
            <section class="about section bd-container" id="about">
                <div class="about__container  bd-grid">
                    <div class="about__data">
                        <span class="section-subtitle about__initial">About us</span>
                        <h2 class="section-title about__initial">Welcome to ROCKY'S PALACE. </h2><h4>Where the flavors of Africa comes alive!</h4>
                        <p class="about__description">Our resturant is dedicated to serving authentic, delicious African cuisine that will transport your taste buds to the heart of the continent. <br> From spicy jollof rice
                        to savory suya, our menu feutures a wide range of traditional African dishes made with love and care. <br>Come and experience the warmth and hospitality of Africa in every bite</p>
                        <a href="https://wa.me/+2348180133531" class="button">Place An Order</a>
                    </div>

                    <img src="images/about.jpg" alt="" class="about__img">
                </div>
            </section>

